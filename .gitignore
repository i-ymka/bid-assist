# .gitignore

# ----------------------------------------------------------------
# 1. Игнорируем секреты и локальную конфигурацию
# Никогда не добавляйте в Git файлы с токенами и паролями!
.env

# ----------------------------------------------------------------
# 2. Игнорируем артефакты Python
# Кэш-файлы, которые Python создает для ускорения работы
__pycache__/
# Виртуальные окружения (если будете создавать локально)
.venv/
venv/

# ----------------------------------------------------------------
# 3. Игнорируем файлы состояния и данные
# Логи работы приложения
logs/
# База данных SQLite с обработанными проектами
*.db
*.sqlite3

# ----------------------------------------------------------------
# 4. Игнорируем конфигурации IDE (опционально, но рекомендуется)
.idea/
.vscode/
.DS_Store