# .gitignore

# ================================================================
# Secrets and local configuration
# ================================================================
.env
.env.*
*.env.local

# ================================================================
# Python artifacts
# ================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# ================================================================
# Application data
# ================================================================
# SQLite databases
*.db
*.sqlite3

# Runtime data and logs (keep dirs via .gitkeep)
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep
*.log

# ================================================================
# Project docs and prompts (internal, not for repo)
# ================================================================
docs/
prompts_*/*

# ================================================================
# IDE and editor files
# ================================================================
.idea/
.vscode/
.cursor/
.claude/
*.swp
*.swo
*~

# macOS
.DS_Store

# ================================================================
# Testing and coverage
# ================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ================================================================
# Type checking
# ================================================================
.mypy_cache/
