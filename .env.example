# .env.example
# --- Freelancer API ---
FREELANCER_OAUTH_TOKEN=YOUR_FREELANCER_OAUTH_TOKEN

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- OpenAI API ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
LLM_MODEL=gpt-4o-mini
MAX_LLM_CALLS_PER_DAY=300

# --- Filtering Settings ---
WL="zapier,google sheet,python script" # Ключевые слова через запятую
BL="raspberry,laravel,ocr"             # Стоп-слова через запятую
MIN_BUDGET=20
MAX_BUDGET=150

# --- App Settings ---
POLL_INTERVAL=300 # Интервал опроса API в секундах (5 минут)
LOG_LEVEL=INFO # Уровень логирования: DEBUG, INFO, WARNING, ERROR