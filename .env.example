# .env.example
# This is an example file. Copy it to .env and fill in your actual values.
# NEVER commit the .env file to Git.

# --- API Keys & Tokens (Required) ---
FREELANCER_OAUTH_TOKEN=YOUR_FREELANCER_OAUTH_TOKEN_WITH_BIDS_SCOPE
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
# Add one or more chat IDs, separated by commas
TELEGRAM_CHAT_IDS=YOUR_TELEGRAM_CHAT_ID,ANOTHER_CHAT_ID
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# --- LLM Settings (Optional) ---
LLM_MODEL=gpt-4o-mini

# --- Filtering Settings ---
# Whitelist keywords to search for in project titles/descriptions
WL="python,script,bot,api,automation,scraping,telegram,zapier,make"

# Blacklist keywords to exclude projects
BL="trading,forex,crypto,blockchain,casino,betting,gambling,cheat,hack,exploit,3d,marketing"

# Skill IDs to filter projects by category (VERY IMPORTANT)
# Example: 13=Python, 711=Telegram API, 135=Web Scraping, 1166=Bot Development
SKILL_IDS="13,711,135,1166,2269,21,31,41,104,114,134,136,178,259,871"

# Budget range in USD
MIN_BUDGET=20
MAX_BUDGET=250

# --- Application Settings ---
# How often to check for new projects, in seconds (300 = 5 minutes)
POLL_INTERVAL=300
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- User Details for Bid Generation ---
USERNAME="Your Name"
PORTFOLIO_URL="https://your-portfolio.com"