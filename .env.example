# .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to Git!

# ============================================
# REQUIRED API KEYS & TOKENS
# ============================================

# Freelancer OAuth token (must have 'bids' scope for bidding)
FREELANCER_OAUTH_TOKEN=YOUR_FREELANCER_OAUTH_TOKEN

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram chat IDs to receive notifications (comma-separated)
TELEGRAM_CHAT_IDS=YOUR_CHAT_ID,ANOTHER_CHAT_ID

# Gemini API key for AI analysis (free tier available)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ============================================
# AI SETTINGS
# ============================================

# Gemini model for CLI analysis (primary)
# Fallback chain on 429: primary → each fallback in order
# When new models appear, just change this value
GEMINI_MODEL=gemini-2.5-pro

# ============================================
# PROJECT FILTERING
# ============================================

# NOTE: Budget range, verified account status, preferred-only filtering,
# and poll interval are now configured via the Telegram bot /settings command.
# These settings are stored in the database and can be changed in real-time.

# Blacklist keywords - projects containing these will be skipped
BL="trading,forex,crypto,blockchain,casino,betting,gambling,cheat,hack,exploit,3d,marketing"

# Skill IDs to filter projects (comma-separated)
# Find IDs at: https://www.freelancer.com/api/projects/0.1/jobs/
# Common IDs:
#   13 = Python, 95 = Web Scraping, 116 = Software Architecture
#   305 = MySQL, 500 = Node.js, 613 = Software Development
SKILL_IDS="13,116,305,500,613,741,954,962,1092,2299,95,1323,1977,3112,2164,2165,2916,292,1039,2719,2878,2986,3132"

# Country filter (whitelist OR blacklist, not both)
# If ALLOWED_COUNTRIES is set, only those countries are accepted
# If BLOCKED_COUNTRIES is set, those countries are rejected
# Leave both empty to accept all countries
ALLOWED_COUNTRIES=
BLOCKED_COUNTRIES=india,pakistan,bangladesh

# Block projects with unknown client country (true/false)
# Set to true if you're using BLOCKED_COUNTRIES and want to ensure
# projects from blocked countries can't slip through as "Unknown"
BLOCK_UNKNOWN_COUNTRIES=true

# Blocked currencies (comma-separated currency codes)
# Projects with these currencies will be filtered out
# Common codes: INR (Indian Rupee), PKR (Pakistani Rupee), BDT (Bangladeshi Taka)
BLOCKED_CURRENCIES=INR

# Maximum project age in hours (older projects are skipped)
MAX_PROJECT_AGE_HOURS=2

# Project languages to accept (comma-separated language codes)
# Only projects in these languages will be shown
# Find your languages at: Freelancer.com → Settings → Browse Projects
# Common codes: en (English), es (Spanish), de (German), fr (French), ru (Russian)
LANGUAGES=en

# Keywords that require verified account (comma-separated)
# Projects with these keywords in title/description/skills will be filtered if not verified
VERIFICATION_KEYWORDS=cryptocurrency,crypto,bitcoin,blockchain,nft,web3

# Maximum number of bids on a project (skip if more bids already placed)
MAX_BID_COUNT=100

# Delay between AI requests in seconds (to avoid rate limits)
AI_REQUEST_DELAY=15

# Testing mode: clear all processed projects on startup (true/false)
# Use this when testing to get immediate notifications
RESET_ON_START=false

# ============================================
# BID SETTINGS
# ============================================

# Default delivery period in days (when AI doesn't suggest one)
DEFAULT_BID_PERIOD=3

# Milestone percentage (100 = full payment at end)
DEFAULT_MILESTONE_PCT=100

# ============================================
# APPLICATION SETTINGS
# ============================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Database path (relative to working directory)
DB_PATH=data/processed_projects.db

# ============================================
# USER PROFILE (for bid proposals)
# ============================================

# Your Freelancer username
USERNAME="Your Name"

# Your portfolio URL
PORTFOLIO_URL="https://your-portfolio.com"

